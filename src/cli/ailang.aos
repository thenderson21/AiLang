            StrConcat#cli_sc42rpm2 {
              Lit#cli_i42rpm2(value="kind = \"")
              StrConcat#cli_sc42rpm3 {
                Var#cli_v42rpm1(name=kind)
                StrConcat#cli_sc42rpm4 {
                  Lit#cli_i42rpm3(value="\"\nmode = \"")
                  StrConcat#cli_sc42rpm5 {
                    Var#cli_v42rpm2(name=mode)
                    StrConcat#cli_sc42rpm6 {
                      Lit#cli_i42rpm4(value="\"\ntarget = \"")
                      StrConcat#cli_sc42rpm7 {
                        Var#cli_v42rpm3(name=target)
                        StrConcat#cli_sc42rpm8 {
                          Lit#cli_i42rpm5(value="\"\nproject = \"")
                          StrConcat#cli_sc42rpm9 {
                            Var#cli_v42rpm4(name=projectName)
                            StrConcat#cli_sc42rpm10 {
                              Lit#cli_i42rpm6(value="\"\nversion = \"")
                              StrConcat#cli_sc42rpm11 {
                                Var#cli_v42rpm5(name=projectVersion)
                                StrConcat#cli_sc42rpm12 {
