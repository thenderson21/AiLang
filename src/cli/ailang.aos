                                    Var#cli_v42rpm6(name=entryFile)
                                    StrConcat#cli_sc42rpm14 {
                                      Lit#cli_i42rpm8(value="\"\nentryExport = \"")
                                      StrConcat#cli_sc42rpm15 { Var#cli_v42rpm7(name=entryExport) Lit#cli_i42rpm9(value="\"\npayload = \"app.aibe\"\n") }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

  Let#cli_l42rp(name=runBootstrapPublish) {
    Fn#cli_f42rp(params=path,target,outDir) {
      Block#cli_b42rp {
        Let#cli_l42rpc(name=compilerPath) { Call#cli_c42rp0(target=resolveBootstrapCompiler) { Var#cli_v42rp0(name=path) } }
        Let#cli_l42rpa(name=spawnArgs) { Call#cli_c42rp1(target=makePublishSpawnArgs) { Var#cli_v42rp1(name=path) Var#cli_v42rp2(name=target) Var#cli_v42rp3(name=outDir) } }
        Let#cli_l42rpe(name=env) { MakeBlock#cli_mb42rp1 { Lit#cli_i42rp1(value="env") } }
        Let#cli_l42rph(name=handle) { Call#cli_c42rp2(target=sys.process.spawn) { Var#cli_v42rp4(name=compilerPath) Var#cli_v42rp5(name=spawnArgs) Lit#cli_i42rp2(value="") Var#cli_v42rp6(name=env) } }
        Let#cli_l42rpc2(name=code) { Call#cli_c42rp3(target=sys.process.wait) { Var#cli_v42rp7(name=handle) } }
        Let#cli_l42rpo(name=stdoutText) { Call#cli_c42rp4(target=sys.bytes.toUtf8String) { Call#cli_c42rp5(target=sys.process.stdout.read) { Var#cli_v42rp8(name=handle) } } }
        Let#cli_l42rps(name=stderrText) { Call#cli_c42rp6(target=sys.bytes.toUtf8String) { Call#cli_c42rp7(target=sys.process.stderr.read) { Var#cli_v42rp9(name=handle) } } }
        If#cli_if42rp1 {
          Eq#cli_e42rp1 { Var#cli_v42rp10(name=code) Lit#cli_i42rp3(value=0) }
          Block#cli_b42rp1 {
            Call#cli_c42rp8(target=sys.stdout.writeLine) { StrConcat#cli_sc42rp1 { Lit#cli_i42rp4(value="Ok#ok1(type=string value=\"") StrConcat#cli_sc42rp2 { Var#cli_v42rp11(name=outDir) Lit#cli_i42rp5(value="\")") } } }
            Return#cli_r42rp1 { Lit#cli_i42rp6(value=0) }
          }
          Block#cli_b42rp2 {
            If#cli_if42rp2 {
              Eq#cli_e42rp2 { Var#cli_v42rp12(name=stderrText) Lit#cli_i42rp7(value="") }
              Block#cli_b42rp3 { Lit#cli_i42rp8(value=0) }
              Block#cli_b42rp4 { Call#cli_c42rp9(target=sys.stdout.writeLine) { Var#cli_v42rp13(name=stderrText) } }
            }
            If#cli_if42rp3 {
              Eq#cli_e42rp3 { Var#cli_v42rp14(name=stdoutText) Lit#cli_i42rp9(value="") }
              Block#cli_b42rp5 { Lit#cli_i42rp10(value=0) }
              Block#cli_b42rp6 { Call#cli_c42rp10(target=sys.stdout.writeLine) { Var#cli_v42rp15(name=stdoutText) } }
            }
            Return#cli_r42rp2 { Call#cli_c42rp11(target=buildError) { Lit#cli_i42rp11(value="AILANG015") Lit#cli_i42rp12(value="Bootstrap compiler publish failed.") Lit#cli_i42rp13(value="publish") } }
          }
        }
      }
    }
  }

  Let#cli_l42ma(name=makePublishSpawnArgs) {
    Fn#cli_f42ma(params=path,target,outDir) {
      Block#cli_b42ma {
        If#cli_if42ma {
          Eq#cli_e42ma { Var#cli_v42ma1(name=target) Lit#cli_i42ma1(value="") }
          Block#cli_b42ma1 {
            Return#cli_r42ma1 {
              AppendChild#cli_ap42ma1 {
                AppendChild#cli_ap42ma2 {
                  AppendChild#cli_ap42ma3 {
                    AppendChild#cli_ap42ma4 {
                      MakeBlock#cli_mb42ma1 { Lit#cli_i42ma2(value="args") }
                      MakeLitString#cli_mls42ma1 { Lit#cli_i42ma3(value="arg0") Lit#cli_i42ma4(value="publish") }
                    }
                    MakeLitString#cli_mls42ma2 { Lit#cli_i42ma5(value="arg1") Var#cli_v42ma2(name=path) }
                  }
                  MakeLitString#cli_mls42ma3 { Lit#cli_i42ma6(value="arg2") Lit#cli_i42ma7(value="--out") }
                }
                MakeLitString#cli_mls42ma4 { Lit#cli_i42ma8(value="arg3") Var#cli_v42ma3(name=outDir) }
              }
            }
          }
          Block#cli_b42ma2 {
            Return#cli_r42ma2 {
              AppendChild#cli_ap42ma5 {
                AppendChild#cli_ap42ma6 {
                  AppendChild#cli_ap42ma7 {
                    AppendChild#cli_ap42ma8 {
                      AppendChild#cli_ap42ma9 {
                        AppendChild#cli_ap42ma10 {
                          MakeBlock#cli_mb42ma2 { Lit#cli_i42ma9(value="args") }
                          MakeLitString#cli_mls42ma5 { Lit#cli_i42ma10(value="arg0") Lit#cli_i42ma11(value="publish") }
                        }
                        MakeLitString#cli_mls42ma6 { Lit#cli_i42ma12(value="arg1") Var#cli_v42ma4(name=path) }
                      }
                      MakeLitString#cli_mls42ma7 { Lit#cli_i42ma13(value="arg2") Lit#cli_i42ma14(value="--target") }
                    }
                    MakeLitString#cli_mls42ma8 { Lit#cli_i42ma15(value="arg3") Var#cli_v42ma5(name=target) }
                  }
                  MakeLitString#cli_mls42ma9 { Lit#cli_i42ma16(value="arg4") Lit#cli_i42ma17(value="--out") }
                }
                MakeLitString#cli_mls42ma10 { Lit#cli_i42ma18(value="arg5") Var#cli_v42ma6(name=outDir) }
              }
            }
          }
        }
      }
    }
  }

  Let#cli_l42po(name=resolvePublishOutDir) {
    Fn#cli_f42po(params=path,outDir) {
      Block#cli_b42po {
        If#cli_if42po {
          Eq#cli_e42po { Var#cli_v42po1(name=outDir) Lit#cli_i42po1(value="") }
          Block#cli_b42po1 { Return#cli_r42po1 { StrConcat#cli_sc42po1 { Var#cli_v42po2(name=path) Lit#cli_i42po2(value="/dist") } } }
          Block#cli_b42po2 { Return#cli_r42po2 { Var#cli_v42po3(name=outDir) } }
        }
      }
    }
  }

  Let#cli_l43(name=runClean) {
    Fn#cli_f43(params=args) {
      Block#cli_b63 {
        Let#cli_l43p(name=path) { Call#cli_c43p(target=readArg) { Var#cli_v43p(name=args) Lit#cli_i43p(value=1) } }
        If#cli_if43p {
          Eq#cli_e43p { Var#cli_v43p2(name=path) Lit#cli_i43pe(value="") }
          Block#cli_b43p { Return#cli_r43p { Call#cli_c43m(target=missingPath) { Lit#cli_i43m(value="clean") } } }
          Block#cli_b43q { Return#cli_r43q { Call#cli_c43c(target=cleanProject) { Var#cli_v43p3(name=path) } } }
        }
      }
    }
  }

  Let#cli_l43cp(name=cleanProject) {
    Fn#cli_f43cp(params=path) {
      Block#cli_b43cp {
        Let#cli_l43cpm(name=manifestPath) { StrConcat#cli_sc43cp1 { Var#cli_v43cp1(name=path) Lit#cli_i43cp1(value="/project.aiproj") } }
        If#cli_if43cp1 {
          Call#cli_c43cp1(target=sys.fs.path.exists) { Var#cli_v43cpm(name=manifestPath) }
          Block#cli_b43cp1 {
            Call#cli_c43cp2(target=deleteDirIfExists) { StrConcat#cli_sc43cp2 { Var#cli_v43cp2(name=path) Lit#cli_i43cp2(value="/bin") } }
            Call#cli_c43cp3(target=deleteDirIfExists) { StrConcat#cli_sc43cp3 { Var#cli_v43cp3(name=path) Lit#cli_i43cp3(value="/dist") } }
            Call#cli_c43cp4(target=deleteDirIfExists) { StrConcat#cli_sc43cp4 { Var#cli_v43cp4(name=path) Lit#cli_i43cp4(value="/.toolchain") } }
            Call#cli_c43cp5(target=sys.stdout.writeLine) { Lit#cli_i43cp5(value="Ok#ok1(type=string value=\"clean-complete\")") }
            Return#cli_r43cp1 { Lit#cli_i43cp6(value=0) }
          }
          Block#cli_b43cp2 { Return#cli_r43cp2 { Call#cli_c43cpe(target=buildError) { Lit#cli_i43cp7(value="AILANG007") Lit#cli_i43cp8(value="project.aiproj not found.") Lit#cli_i43cp9(value="project") } } }
        }
      }
    }
  }

  Let#cli_l43dd(name=deleteDirIfExists) {
    Fn#cli_f43dd(params=path) {
      Block#cli_b43dd {
        If#cli_if43dd {
          Call#cli_c43dd1(target=sys.fs.path.exists) { Var#cli_v43dd1(name=path) }
          Block#cli_b43dd1 {
            Call#cli_c43dd2(target=sys.fs.dir.delete) { Var#cli_v43dd2(name=path) Lit#cli_i43dd1(value=true) }
            Return#cli_r43dd1 { Lit#cli_i43dd2(value=0) }
          }
          Block#cli_b43dd2 { Return#cli_r43dd2 { Lit#cli_i43dd3(value=0) } }
        }
      }
    }
  }

  Let#cli_l50(name=missingPath) {
    Fn#cli_f50(params=command) {
      Block#cli_b70 {
        Call#cli_c50(target=sys.stdout.writeLine) {
          StrConcat#cli_sc1 {
