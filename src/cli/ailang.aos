                Lit#cli_i42rpl5(value="#!/usr/bin/env sh\nset -eu\nAPP_ROOT=\"$(CDPATH= cd -- \"$(dirname -- \"$0\")/..\" && pwd)\"\nexec aivm \"$APP_ROOT/lib/ailang/")
                StrConcat#cli_sc42rpl6 { Var#cli_v42rpl4(name=projectName) Lit#cli_i42rpl6(value="/app.aibe\" \"$@\"\n") }
              }
            }
          }
        }
      }
    }
  }

  Let#cli_l42rcl(name=renderCmdLauncher) {
    Fn#cli_f42rcl(params=projectName,mode) {
      Block#cli_b42rcl {
        If#cli_if42rcl {
          Eq#cli_e42rcl { Var#cli_v42rcl1(name=mode) Lit#cli_i42rcl1(value="self-contained") }
          Block#cli_b42rcl1 {
            Return#cli_r42rcl1 {
              StrConcat#cli_sc42rcl1 {
                Lit#cli_i42rcl2(value="@echo off\r\nset APP_ROOT=%~dp0..\r\n\"%APP_ROOT%\\lib\\ailang\\")
                StrConcat#cli_sc42rcl2 {
                  Var#cli_v42rcl2(name=projectName)
                  StrConcat#cli_sc42rcl3 {
                    Lit#cli_i42rcl3(value="\\runtime\\aivm.exe\" \"%APP_ROOT%\\lib\\ailang\\")
                    StrConcat#cli_sc42rcl4 { Var#cli_v42rcl3(name=projectName) Lit#cli_i42rcl4(value="\\app.aibe\" %*\r\n") }
                  }
                }
              }
            }
          }
          Block#cli_b42rcl2 {
            Return#cli_r42rcl2 {
              StrConcat#cli_sc42rcl5 {
                Lit#cli_i42rcl5(value="@echo off\r\nset APP_ROOT=%~dp0..\r\naivm \"%APP_ROOT%\\lib\\ailang\\")
                StrConcat#cli_sc42rcl6 { Var#cli_v42rcl4(name=projectName) Lit#cli_i42rcl6(value="\\app.aibe\" %*\r\n") }
              }
            }
          }
        }
      }
    }
  }

  Let#cli_l42rpm(name=renderPublishManifest) {
